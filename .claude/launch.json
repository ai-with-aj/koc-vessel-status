{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "vessel-status",
      "runtimeExecutable": "/Users/a.gharaballi/.node/bin/node",
      "runtimeArgs": ["-e", "require('http').createServer((req,res)=>{const fs=require('fs'),path=require('path');let f=path.join('/Users/a.gharaballi/Desktop/vessel status',req.url==='/'?'/index.html':req.url);fs.readFile(f,(e,d)=>{if(e){res.writeHead(404);res.end('Not found');}else{const ext=path.extname(f);const ct={'html':'text/html','png':'image/png','js':'text/javascript','css':'text/css','json':'application/json'}[ext.slice(1)]||'text/plain';res.writeHead(200,{'Content-Type':ct});res.end(d);}});}).listen(7777)"],
      "port": 7777
    }
  ]
}
